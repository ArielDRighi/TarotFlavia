# Backend API URL (must include /api/v1)
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# Frontend URL
NEXT_PUBLIC_APP_URL=http://localhost:3001

# App Environment
NEXT_PUBLIC_APP_ENV=development

# -----------------------------------------------------------------------------
# Staging Access Control
# -----------------------------------------------------------------------------
# These variables control UI behavior for staging environments.
# NOTE: Do NOT pass the actual email list to the frontend — only use boolean flags.

# Show whitelist restriction notice on /registro page
# true = show notice that registration is limited to testers
# false or undefined = normal registration form (production behavior)
# NEXT_PUBLIC_REGISTRATION_WHITELIST_ACTIVE=false

# Enable/disable anonymous access to daily card in the UI
# false = redirect unauthenticated users to /login (staging)
# true or undefined = anonymous access enabled (production behavior)
# NEXT_PUBLIC_ANONYMOUS_ACCESS_ENABLED=true

# Optional: Analytics, Error Tracking, etc. (post-MVP)
# NEXT_PUBLIC_ANALYTICS_ID=
# NEXT_PUBLIC_SENTRY_DSN=
