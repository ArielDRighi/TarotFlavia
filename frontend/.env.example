# Backend API URL (must include /api/v1)
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# Frontend URL
# ⚠️ De esta variable depende la INDEXACIÓN (T-PROD-018): solo se indexa si el host
# es el dominio productivo (ver src/lib/metadata/indexing.ts). Staging, los previews
# de Railway y local quedan con `Disallow: /` + `noindex` automáticamente, sin ningún
# flag extra que haya que acordarse de apagar.
NEXT_PUBLIC_APP_URL=http://localhost:3001

# App Environment
NEXT_PUBLIC_APP_ENV=development

# -----------------------------------------------------------------------------
# Staging Access Control
# -----------------------------------------------------------------------------
# These variables control UI behavior for staging environments.
# NOTE: Do NOT pass the actual email list to the frontend — only use boolean flags.

# Show whitelist restriction notice on /registro page
# true = show notice that registration is limited to testers
# false or undefined = normal registration form (production behavior)
# NEXT_PUBLIC_REGISTRATION_WHITELIST_ACTIVE=false

# Enable/disable anonymous access to daily card in the UI
# false = require authentication and show the unauthenticated access UI/CTAs (staging)
# true or undefined = anonymous access enabled (production behavior)
# NEXT_PUBLIC_ANONYMOUS_ACCESS_ENABLED=true

# -----------------------------------------------------------------------------
# Google AdSense (T-PROD-008)
# -----------------------------------------------------------------------------
# Publisher ID de AdSense (formato: ca-pub-XXXXXXXXXXXXXXXX).
# Actúa como kill-switch: si está VACÍA o no definida, no se carga el loader de
# AdSense ni se renderiza ningún AdSlot (cero rastro de AdSense en dev/staging).
# El ID real se obtiene al aprobarse la cuenta (T-PROD-009); solo se setea en producción.
# Los anuncios se muestran a usuarios anónimos y Free; los Premium nunca los ven.
# NEXT_PUBLIC_ADSENSE_CLIENT=

# -----------------------------------------------------------------------------
# Notificaciones in-app (T-PROD-011)
# -----------------------------------------------------------------------------
# Las notificaciones NO están planeadas en la web por ahora. La feature está
# implementada completa (campana + dropdown + backend), pero queda OCULTA y
# BLOQUEADA: sin este flag en 'true' la campana no se monta y el frontend no
# hace ninguna petición a /notifications.
# Poner en 'true' para reactivarla en el futuro.
# NEXT_PUBLIC_NOTIFICATIONS_ENABLED=false

# Optional: Analytics, Error Tracking, etc. (post-MVP)
# NEXT_PUBLIC_ANALYTICS_ID=
# NEXT_PUBLIC_SENTRY_DSN=
