<html lang='es'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Pago confirmado - {{serviceName}}</title>
    <style>
      body {
        font-family: 'Georgia', serif;
        background-color: #f5f3f0;
        margin: 0;
        padding: 0;
      }
      .container {
        max-width: 600px;
        margin: 0 auto;
        background-color: #ffffff;
        padding: 40px 30px;
        border-radius: 10px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      }
      .header {
        text-align: center;
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 2px solid #f0ebe4;
      }
      .header-icon {
        font-size: 60px;
        margin-bottom: 10px;
      }
      .header h1 {
        color: #8b7355;
        font-size: 28px;
        margin: 10px 0 5px 0;
        font-weight: normal;
      }
      .header p {
        color: #9e8c78;
        font-size: 15px;
        margin: 0;
      }
      .content {
        color: #5a5a5a;
        font-size: 16px;
        line-height: 1.8;
        margin: 20px 0;
      }
      .content p {
        margin: 15px 0;
      }
      .service-box {
        background-color: #f9f7f5;
        padding: 25px;
        border-radius: 8px;
        margin: 25px 0;
        border-left: 4px solid #8b7355;
      }
      .service-box h2 {
        color: #8b7355;
        font-size: 20px;
        margin-top: 0;
        margin-bottom: 20px;
      }
      .detail-row {
        display: flex;
        justify-content: space-between;
        padding: 10px 0;
        border-bottom: 1px solid #ede9e4;
        font-size: 15px;
      }
      .detail-row:last-child {
        border-bottom: none;
      }
      .detail-label {
        color: #888;
        font-size: 14px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }
      .detail-value {
        color: #3a3a3a;
        font-weight: bold;
        font-size: 15px;
        text-align: right;
      }
      .whatsapp-box {
        background-color: #f0faf4;
        border: 1px solid #c3e6cb;
        border-radius: 8px;
        padding: 20px 25px;
        margin: 25px 0;
        text-align: center;
      }
      .whatsapp-box .whatsapp-icon {
        font-size: 36px;
        margin-bottom: 8px;
      }
      .whatsapp-box h3 {
        color: #2d6a4f;
        font-size: 16px;
        margin: 0 0 8px 0;
        font-weight: normal;
      }
      .whatsapp-number {
        color: #1a5c3a;
        font-size: 22px;
        font-weight: bold;
        letter-spacing: 1px;
        margin: 5px 0;
      }
      .whatsapp-box .wa-link {
        display: inline-block;
        margin-top: 10px;
        background-color: #25d366;
        color: #ffffff;
        padding: 10px 20px;
        text-decoration: none;
        border-radius: 5px;
        font-size: 14px;
        font-weight: bold;
      }
      .cta-button {
        display: block;
        text-align: center;
        background-color: #8b7355;
        color: #ffffff;
        padding: 15px 30px;
        text-decoration: none;
        border-radius: 5px;
        margin: 30px auto;
        max-width: 260px;
        font-size: 16px;
        font-weight: bold;
      }
      .note-box {
        background-color: #fefce8;
        border: 1px solid #fde68a;
        border-radius: 6px;
        padding: 15px 20px;
        margin: 20px 0;
        font-size: 14px;
        color: #78350f;
        line-height: 1.6;
      }
      .footer {
        text-align: center;
        margin-top: 40px;
        padding-top: 20px;
        border-top: 1px solid #e0e0e0;
        color: #888;
        font-size: 13px;
      }
      .footer p {
        margin: 5px 0;
      }
      /* Placeholder branding — completar cuando se compre dominio de mail */
      /* .logo { max-width: 150px; } */
      /* .brand-color { color: #8b7355; } */
    </style>
  </head>
  <body>
    <div class='container'>

      <!-- HEADER -->
      <div class='header'>
        <div class='header-icon'>✨</div>
        <h1>¡Pago confirmado!</h1>
        <p>Tu reserva para <strong>{{serviceName}}</strong> está lista</p>
      </div>

      <!-- SALUDO -->
      <div class='content'>
        <p>Hola <strong>{{userName}}</strong>,</p>
        <p>
          Tu pago fue aprobado exitosamente. Ya podés reservar tu turno y
          contactar a Flavia a través de WhatsApp para coordinar los detalles
          de tu sesión.
        </p>
      </div>

      <!-- DETALLE DEL SERVICIO -->
      <div class='service-box'>
        <h2>Detalle de tu servicio</h2>

        <div class='detail-row'>
          <span class='detail-label'>Servicio</span>
          <span class='detail-value'>{{serviceName}}</span>
        </div>
        <div class='detail-row'>
          <span class='detail-label'>Monto pagado</span>
          <span class='detail-value'>$ {{amountArs}} ARS</span>
        </div>
      </div>

      <!-- WHATSAPP DE FLAVIA -->
      <div class='whatsapp-box'>
        <div class='whatsapp-icon'>📱</div>
        <h3>Número de WhatsApp de Flavia</h3>
        <div class='whatsapp-number'>{{whatsappNumber}}</div>
        <a
          href='https://wa.me/{{whatsappNumber}}'
          class='wa-link'
        >Abrir en WhatsApp</a>
      </div>

      <!-- NOTA: disponibilidad de fechas -->
      <div class='note-box'>
        <strong>Importante:</strong>
        Las fechas disponibles son al momento de la consulta. Una vez realizado
        el pago, la fecha que observaste libre podría ya estar ocupada.
        Reservá tu turno lo antes posible.
      </div>

      <!-- CTA: reservar turno -->
      <a href='{{bookingUrl}}' class='cta-button'>Reservar mi turno</a>

      <!-- FOOTER -->
      <div class='footer'>
        <!-- Placeholder branding — completar con logo cuando se compre dominio -->
        <p>✨ Auguria — Plataforma de Servicios Místicos ✨</p>
        <p>
          Este email fue generado automáticamente. Por favor no respondas a
          este mensaje.
        </p>
        <!-- TODO: agregar dirección física / redes sociales cuando estén disponibles -->
      </div>

    </div>
  </body>
</html>
