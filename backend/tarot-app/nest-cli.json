{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "watchAssets": true,
    "assets": [
      {
        "include": "modules/birth-chart/assets/fonts/*.ttf",
        "outDir": "dist/src"
      },
      {
        "include": "modules/email/templates/**/*.hbs",
        "outDir": "dist/src"
      }
    ]
  }
}
